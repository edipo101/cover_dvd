APP_ENV=development
APP_DEBUG=true

# --- API KEYS ---
TMDB_API_KEY=your_api_key
TMDB_LANGUAGE=es-ES
ANILIST_API_URL=https://graphql.anilist.co

# --- RUTAS LOCALES ---
OUTPUT_DIR="./output"
ASSETS_DIR="./assets"

# --- CONFIGURACIÓN DE IMPRESIÓN ---
COVER_WIDTH_PX=1572
COVER_HEIGHT_PX=1064
COVER_SPINE_PX=96
COVER_DPI=150

# --- Colores de estaciones para el lomo ---
SEASON_WINTER=(240, 148, 117)
SEASON_SPRING=(0, 146, 70)
SEASON_SUMMER=(226, 177, 74)
SEASON_FALL=(153, 189, 115)